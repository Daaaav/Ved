msgctxt "L.OSNOTRECOGNIZED"
msgid ""
"Your operating system ($1) is not recognized! Falling back to default filesystem functions; levels are stored in:\n"
"\n"
"$2"
msgstr ""
"Votre système d'exploitation ($1) n'est pas reconnu! Utilisation des valeurs par défaut des fonctions du système de fichiers; les niveaux sont stockés dans:\n"
"\n"
"$2"

msgctxt "L.MAXTRINKETS"
msgid "The maximum amount of trinkets ($1) has been reached in this level."
msgstr "Le nombre maximum de médailles ($1) a été atteint dans ce niveau."

msgctxt "L.MAXCREWMATES"
msgid "The maximum amount of crewmates ($1) has been reached in this level."
msgstr "Le nombre maximum d'équipiers ($1) a été atteint dans ce niveau."

msgctxt "L.UNSUPPORTEDTOOL"
msgid "Unsupported tool! Tool: "
msgstr "Outil non supporté! Outil : "

msgctxt "L.COULDNOTGETCONTENTSLEVELFOLDER"
msgid "Could not get contents of levels folder. Please check if $1 exists and try again."
msgstr "Le contenu du dossier de niveaux n'a pas pu être récupéré. Veuillez vérifier si $1 existe et réessayez."

msgctxt "L.MAPSAVEDAS"
msgid "Map image saved as $1!"
msgstr "L'image de la carte a été sauvegardée en tant que $1 !"

msgctxt "L.RAWENTITYPROPERTIES"
msgid "You can change the raw property values of this entity here."
msgstr "Vous pouvez changer les valeurs brutes des propriétés de cette entité ici."

msgctxt "L.UNKNOWNENTITYTYPE"
msgid "Unknown entity type $1"
msgstr "Type d'entité $1 inconnu"

msgctxt "L.WARPTOKENENT404"
msgid "Warp token entity no longer exists!"
msgstr "Le jeton de téléportation n'existe plus !"

#. Command names are best left untranslated
msgctxt "L.SPLITFAILED"
msgid "Split failed miserably! Do you have too many lines between a text command and a speak/speak_active?"
msgstr "La séparation a misérablement échoué ! Avez-vous trop de lignes entre une commande texte et une commande speak ou speak_active ?"

msgctxt "L.NOFLAGSLEFT"
msgid "There are no flags left, so one or more new flag labels in this script cannot be associated with any flag number. Trying to run this script in VVVVVV may break. Consider removing all references to flags you no longer need and try again."
msgstr "Il n'y a plus de drapeaux disponibles, donc au moins un nouveau nom de drapeau ne peut pas être associé à un numéro de drapeau. L'utilisation de ce script dans VVVVVV a des chances de le casser. Veuillez enlever toutes les références vers des drapeaux que vous n'utilisez plus et réessayez."

msgctxt "L.NOFLAGSLEFT_LOADSCRIPT"
msgid "There are no flags left, so a load script using a new flag could not be created. Instead, a load script has been created that always loads the target script with iftrinkets(0,$1). Consider removing all references to flags you no longer need and try again."
msgstr "Il n'y a plus de drapeaux disponibles, donc un script de chargement utilisant un nouveau drapeau n'a pas pu être créé. A la place, un script de chargement qui charge le script cible avec iftrinkets(0,$1) a été créé. Veuillez enlever toutes les références vers des drapeaux que vous n'utilisez plus et réessayez."

msgctxt "L.LEVELOPENFAIL"
msgid "Unable to open $1.vvvvvv."
msgstr "Impossible d'ouvrir le fichier $1.vvvvvv."

msgctxt "L.SIZELIMIT"
msgid ""
"The maximum size of a level is $1 by $2.\n"
"\n"
"The level size will be changed to $3 by $4 instead."
msgstr ""
"La taille maximum d'un niveau est de $1 par $2.\n"
"\n"
"A la place, la taille du niveau va être changée en $3 par $4."

msgctxt "L.SCRIPTALREADYEXISTS"
msgid "Script \"$1\" already exists!"
msgstr "Le script \"$1\" existe déjà !"

msgctxt "L.FLAGNAMENUMBERS"
msgid "Flag names cannot be only numbers."
msgstr "Les noms de drapeaux ne peuvent pas être composés que de nombres."

msgctxt "L.FLAGNAMECHARS"
msgid "Flag names cannot contain parentheses, commas or spaces."
msgstr "Les noms de drapeaux ne peuvent pas contenir de virgules, de parenthèses ou d'espaces."

msgctxt "L.FLAGNAMEINUSE"
msgid "The flag name $1 is already in use by flag $2"
msgstr "Le nom de drapeau $1 est déjà utilisé par le drapeau $2"

msgctxt "L.DIFFSELECT"
msgid "Select the level to compare to. The level you select now will be treated as being an older version."
msgstr "Choisissez le niveau à comparer. Le niveau que vous sélectionnez sera considéré comme l'ancienne version."

msgctxt "L.SUREQUITNEW"
msgid "You have unsaved changes. Do you want to save these changes before quitting?"
msgstr "Vous avez des changements non sauvegardés. Voulez-vous sauver ces changements avant de quitter ?"

msgctxt "L.SURENEWLEVELNEW"
msgid "You have unsaved changes. Do you want to save these changes before creating a new level?"
msgstr "Vous avez des changements non sauvegardés. Voulez-vous sauver ces changements avant de créer un nouveau niveau ?"

msgctxt "L.SUREOPENLEVEL"
msgid "You have unsaved changes. Do you want to save these changes before opening this level?"
msgstr "Vous avez des changements non sauvegardés. Voulez-vous sauvegarder ces changements avant d'ouvrir ce niveau ?"

