msgctxt "L.MDEVERSIONWARNING"
msgid "This level appears to have been made in a more recent version of Ved, and may contain some data which will be lost when you save this level."
msgstr "Ĉi tiu nivelo ŝajnas esti kreita per pli nova versio de Ved, kaj eble enhavas iujn datumojn, kiuj perdiĝos kiam vi konservas la nivelon."

msgctxt "L.FORGOTPATH"
msgid "You forgot to specify a path!"
msgstr "Vi forgesis specifi dosierindikon!"

msgctxt "L.LIB_LOAD_ERRMSG"
msgid ""
"Failed to load an essential library. Please tell Dav999 about this problem.\n"
"\n"
"$1"
msgstr ""
"Ŝargado de necesa biblioteko malsukcesis. Bonvolu raporti tiun ĉi problemon al Dav999.\n"
"\n"
"$1"

msgctxt "L.LIB_LOAD_ERRMSG_GCC"
msgid ""
"\n"
"\n"
"Try installing GCC to solve this problem, if it isn't already installed."
msgstr ""
"\n"
"\n"
"Provu instali GCC por solvi tiun ĉi problemon, se tiu ne estas jam instalita."

